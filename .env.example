# ===== CONFIGURACIÓN BASE DE HORAS DE BIENESTAR =====
# Copia este archivo a .env y completa con tus valores

# ===== APLICACIÓN =====
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=tu-clave-secreta-muy-larga-y-aleatoria-aqui

# ===== BASE DE DATOS =====
# Para PostgreSQL (Render):
DATABASE_URL=postgresql://user:password@localhost/horas_bienestar
# Para SQLite local:
# DATABASE_URL=sqlite:///instance/app.db

# ===== LOGGING =====
LOG_FILE=app.log
LOG_LEVEL=INFO

# ===== EMAIL SMTP (OBLIGATORIO para recuperación de contraseña) =====
# Ejemplo con Gmail: https://support.google.com/accounts/answer/185833
MAIL_FROM=noreply@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password-generado-en-google
SMTP_USE_TLS=true

# Ejemplo alternativo con otro servidor (Sendgrid, Office365, etc)
# MAIL_FROM=noreply@uccbienestarmonteria.site
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== SMS TWILIO (OPCIONAL - para envío de códigos por SMS) =====
# Crear cuenta en https://www.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890

# ===== ADMIN POR DEFECTO =====
DEFAULT_ADMIN_EMAIL=admin@campusucc.edu.co
DEFAULT_ADMIN_PASSWORD=contraseña-segura-aqui
DEFAULT_ADMIN_NAME=Administrador

# ===== CONFIGURACIÓN DE SEGURIDAD =====
SECURITY_HARDENING_ENABLED=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict
HSTS_SECONDS=31536000

# ===== SESIÓN DE USUARIO =====
SESSION_LIFETIME_HOURS=8
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# ===== HORAS REQUERIDAS =====
REQUIRED_WELLBEING_HOURS=40
